import tkinter as tk
from tkinter import messagebox
import requests
import json
import os

# Основные параметры
API_URL = "https://api.github.com/users/"

# Файл для хранения избранных
FAV_FILE = 'favorites.json'

# Загрузка избранных
def load_favorites():
    if os.path.exists(FAV_FILE):
        with open(FAV_FILE, 'r') as f:
            return json.load(f)
    return []

# Сохранение избранных
def save_favorites(favorites):
    with open(FAV_FILE, 'w') as f:
        json.dump(favorites, f, indent=4)

# Основное приложение
class GitHubUserFinder(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("GitHub User Finder")
        self.geometry("600x400")
        
        self.favorites = load_favorites()
        
        # Поле поиска
        self.search_entry = tk.Entry(self, width=50)
        self.search_entry.pack(pady=10)

        # Кнопка поиска
        self.search_button = tk.Button(self, text="Поиск", command=self.search_user)
        self.search_button.pack()

        # Список результатов
        self.results_listbox = tk.Listbox(self, width=80, height=10)
        self.results_listbox.pack(pady=10)

        # Кнопка добавить в избранное
        self.add_fav_button = tk.Button(self, text="Добавить в избранное", command=self.add_to_favorites)
        self.add_fav_button.pack(pady=5)
        
        # Отобразить текущих избранных
        self.show_favorites()

    def search_user(self):
        query = self.search_entry.get().strip()
        if not query:
            messagebox.showwarning("Ошибка", "Поле поиска не должно быть пустым.")
            return
        response = requests.get(API_URL + query)
        if response.status_code == 200:
            user = response.json()
            self.results_listbox.delete(0, tk.END)
            display_text = f"{user.get('login')} - {user.get('name') or 'Без имени'}"
            self.results_listbox.insert(tk.END, display_text)
        elif response.status_code == 404:
            messagebox.showinfo("Не найдено", "Пользователь не найден.")
        else:
            messagebox.showerror("Ошибка", "Ошибка при обращении к API.")

    def add_to_favorites(self):
        selected = self.results_listbox.curselection()
        if not selected:
            messagebox.showwarning("Выбор", "Выберите пользователя для добавления.")
            return
        user_text = self.results_listbox.get(selected)
        login = user_text.split(' - ')[0]
        # Проверка, есть ли уже в фаворитах
        if any(fav['login'] == login for fav in self.favorites):
            messagebox.showinfo("Информация", "Пользователь уже в избранных.")
            return
        # Получение полной информации о пользователе
        response = requests.get(API_URL + login)
        if response.status_code == 200:
            user_data = response.json()
            self.favorites.append(user_data)
            save_favorites(self.favorites)
            self.show_favorites()
            messagebox.showinfo("Успех", "Пользователь добавлен в избранное.")
        else:
            messagebox.showerror("Ошибка", "Не удалось добавить пользователя.")

    def show_favorites(self):
        # Можно вывести избранных в отдельный списочный блок или в консоль
        print("Избранные пользователи:")
        for fav in self.favorites:
            print(f"{fav.get('login')} - {fav.get('name')}")

if __name__ == "__main__":
    app = GitHubUserFinder()
    app.mainloop()